# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SUPABASE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Trouvé dans : https://supabase.com/dashboard → Settings → API
# "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# "anon public" key (côté client, sans danger d'exposer)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# "service_role" key (côté serveur UNIQUEMENT — ne jamais exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# STRIPE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Trouvé dans : https://dashboard.stripe.com/apikeys
# Clé secrète (commence par sk_live_ en prod, sk_test_ en dev)
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret : https://dashboard.stripe.com/webhooks
# Après avoir créé ton webhook, copie le "Signing secret" (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs des produits/prix dans Stripe
# Crée 3 produits dans Stripe Dashboard → Products → Add product
# Prix récurrents mensuels : 19€, 39€, 79€
# Copie les "Price ID" (price_...)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCE=price_...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RESEND
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Trouvé dans : https://resend.com/api-keys → Create API Key
RESEND_API_KEY=re_...

# L'adresse email depuis laquelle tu envoies (doit être vérifiée dans Resend)
# Resend → Domains → Add domain, puis vérifie le DNS
RESEND_FROM_EMAIL=PostFlow AI <bonjour@tondomaine.com>

# L'email admin qui reçoit les notifications de nouveaux paiements
ADMIN_EMAIL=toi@email.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# L'URL de ton app (localhost en dev, ton domaine en prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mot de passe pour accéder à la page admin (protège /admin)
ADMIN_SECRET_PASSWORD=change_moi_en_prod_mot_de_passe_long
